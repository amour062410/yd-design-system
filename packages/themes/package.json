{
  "name": "@yd-ds/themes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/themes.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@yd-ds/tokens": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@yd-ds/typescript-config": "workspace:*",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
