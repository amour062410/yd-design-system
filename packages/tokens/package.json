{
  "name": "@yd-ds/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.js"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": {
      "types": "./dist/tailwind-preset.d.mts",
      "import": "./dist/tailwind-preset.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@yd-ds/typescript-config": "workspace:*",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
