{
  "name": "docs-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @yd-ds/ui build",
    "dev": "next dev --port 3000",
    "dev:fresh": "rm -rf .next && next dev --port 3000",
    "dev:clean": "sh -c 'lsof -ti :3000 | xargs kill -9 2>/dev/null; rm -rf .next && next dev --port 3000'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@yd-ds/themes": "workspace:*",
    "@yd-ds/tokens": "workspace:*",
    "@yd-ds/ui": "workspace:*",
    "framer-motion": "^12.15.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@yd-ds/typescript-config": "workspace:*",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}